# =============================================================================
# NCRTC Fleet Management Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables here correspond to Settings fields in app/core/config.py.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="NCRTC Fleet Management"
APP_ENV=development                  # development | production
APP_DEBUG=true                       # Enable debug mode (disable in production)
APP_VERSION=1.0.0

# ── Backend Server ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1                    # Uvicorn workers (increase in production)
BACKEND_RELOAD=true                  # Auto-reload on file changes (dev only)

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30   # Access token lifetime
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7      # Refresh token lifetime

# ── Database (PostgreSQL + PostGIS) ──────────────────────────────────────────
POSTGRES_HOST=localhost              # Use "db" when running in Docker Compose
POSTGRES_PORT=5432
POSTGRES_DB=ncrtc_fleet
POSTGRES_USER=ncrtc_admin
POSTGRES_PASSWORD=ncrtc_secure_password_2024
# DATABASE_URL=                      # Override: full async connection string
                                     # e.g. postgresql+asyncpg://user:pass@host:5432/db

# ── GPS Simulator ────────────────────────────────────────────────────────────
GPS_SIMULATOR_ENABLED=true           # Enable autonomous vehicle movement simulation
GPS_SIMULATOR_INTERVAL_SECONDS=5     # Tick interval (seconds between position updates)
GPS_SIMULATOR_VEHICLE_COUNT=50       # Max vehicles to simulate

# ── AI Copilot ───────────────────────────────────────────────────────────────
COPILOT_MODE=demo                    # demo = pattern matching, live = external LLM
GEMINI_API_KEY=                      # Required only when COPILOT_MODE=live

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80","http://localhost"]

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads                   # Directory for uploaded files
UPLOAD_MAX_SIZE_MB=10                # Maximum file size in MB
UPLOAD_ALLOWED_TYPES=["image/jpeg","image/png","application/pdf"]
UPLOAD_ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".pdf"]

# ── Demo Mode ────────────────────────────────────────────────────────────────
DEMO_MODE=false                      # Enable demo mode features

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60             # Max requests per minute per client
