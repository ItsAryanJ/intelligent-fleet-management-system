# =============================================================================
# NCRTC Intelligent Fleet Management Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=NCRTC Fleet Management
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_RELOAD=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ncrtc_fleet
POSTGRES_USER=ncrtc_admin
POSTGRES_PASSWORD=ncrtc_secure_password_2024
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# GPS Simulator
# -----------------------------------------------------------------------------
GPS_SIMULATOR_ENABLED=true
GPS_SIMULATOR_INTERVAL_SECONDS=5
GPS_SIMULATOR_VEHICLE_COUNT=50

# -----------------------------------------------------------------------------
# AI Copilot (Demo Mode)
# -----------------------------------------------------------------------------
COPILOT_MODE=demo
# GEMINI_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Email (Optional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ncrtc.in

# -----------------------------------------------------------------------------
# Redis (Optional - for caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
